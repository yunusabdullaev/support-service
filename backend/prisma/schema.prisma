// Prisma schema for MongoDB
// Hippo Support CRM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  ADMIN
  TEAM_LEADER
  OPERATOR
  DEVELOPER
}

enum BugPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum BugStatus {
  NEW
  CONFIRMED
  IN_PROGRESS
  WAITING
  FIXED
  CLOSED
  REJECTED
}

enum ImprovementStatus {
  NEW
  UNDER_REVIEW
  PLANNED
  IN_DEVELOPMENT
  DONE
  REJECTED
}

enum ServiceStatus {
  ONLINE
  DEGRADED
  OFFLINE
  UNKNOWN
}

enum IncidentSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  CLOSED
}

enum DialogReviewStatus {
  DRAFT
  REVIEWED
  NEEDS_TRAINING
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ArticleCategory {
  CRM
  SIPUNI
  SARKOR
  MODERATOR
  COMMON_QUESTIONS
  TROUBLESHOOTING
  INTERNAL_RULES
}

enum DifficultyStatus {
  NEW
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum InstallationStatus {
  NEW
  IN_PROGRESS
  INSTALLED
}

enum BitrixStatus {
  NOT_ADDED
  ADDED
}

// ==================== MODELS ====================

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  fullName     String
  email        String   @unique
  phone        String?
  telegramChatId String?
  passwordHash String
  role         Role     @default(OPERATOR)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  createdBugs        Bug[]            @relation("BugCreatedBy")
  assignedBugs       Bug[]            @relation("BugAssignedTo")
  bugComments        BugComment[]
  bugAttachments     BugAttachment[]
  dialogReviews      DialogReview[]   @relation("DialogReviewedBy")
  operatorDialogs    DialogReview[]   @relation("DialogOperator")
  createdImprovements ImprovementRequest[] @relation("ImprovementCreatedBy")
  incidentResponsible Incident[]
  createdArticles    KnowledgeArticle[] @relation("ArticleCreatedBy")
  updatedArticles    KnowledgeArticle[] @relation("ArticleUpdatedBy")
  difficulties       Difficulty[]       @relation("DifficultyCreatedBy")
  clientComments     ClientComment[]
  createdClients     Client[]           @relation("ClientCreatedBy")

  @@map("users")
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  bugs            Bug[]
  dialogReviews   DialogReview[]
  improvements    ImprovementRequest[]
  serviceMonitors ServiceMonitor[]
  articles        KnowledgeArticle[]
  difficulties    Difficulty[]
  clients         Client[]

  @@map("products")
}

model DialogReview {
  id                  String             @id @default(auto()) @map("_id") @db.ObjectId
  operatorId          String             @db.ObjectId
  productId           String             @db.ObjectId
  clientName          String
  dialogText          String
  reviewDate          DateTime           @default(now())
  firstResponseScore  Int                @default(0)
  understandingScore  Int                @default(0)
  solutionScore       Int                @default(0)
  communicationScore  Int                @default(0)
  closingScore        Int                @default(0)
  totalScore          Int                @default(0)
  mistakes            String?
  comment             String?
  status              DialogReviewStatus @default(DRAFT)
  reviewedById        String?            @db.ObjectId
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  operator   User    @relation("DialogOperator", fields: [operatorId], references: [id])
  product    Product @relation(fields: [productId], references: [id])
  reviewedBy User?   @relation("DialogReviewedBy", fields: [reviewedById], references: [id])

  @@map("dialog_reviews")
}

model Bug {
  id               String      @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  productId        String      @db.ObjectId
  module           String?
  clientPhone      String?
  description      String
  stepsToReproduce String?
  expectedResult   String?
  actualResult     String?
  priority         BugPriority @default(MEDIUM)
  status           BugStatus   @default(NEW)
  reportedByClientsCount Int  @default(1)
  assignedToId     String?     @db.ObjectId
  createdById      String      @db.ObjectId
  deadline         DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  product     Product         @relation(fields: [productId], references: [id])
  assignedTo  User?           @relation("BugAssignedTo", fields: [assignedToId], references: [id])
  createdBy   User            @relation("BugCreatedBy", fields: [createdById], references: [id])
  attachments BugAttachment[]
  comments    BugComment[]
  upvotes     BugUpvote[]

  @@map("bugs")
}

model BugAttachment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  bugId     String   @db.ObjectId
  userId    String?  @db.ObjectId
  fileUrl   String
  fileName  String
  fileType  String
  createdAt DateTime @default(now())

  bug  Bug   @relation(fields: [bugId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@map("bug_attachments")
}

model BugComment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  bugId     String   @db.ObjectId
  userId    String   @db.ObjectId
  comment   String
  createdAt DateTime @default(now())

  bug  Bug  @relation(fields: [bugId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@map("bug_comments")
}

model ImprovementRequest {
  id                      String            @id @default(auto()) @map("_id") @db.ObjectId
  title                   String
  productId               String            @db.ObjectId
  description             String
  requestedByClientsCount Int               @default(0)
  source                  String?
  clientPhone             String?
  businessValue           String?
  status                  ImprovementStatus @default(NEW)
  createdById             String            @db.ObjectId
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  product   Product @relation(fields: [productId], references: [id])
  createdBy User    @relation("ImprovementCreatedBy", fields: [createdById], references: [id])
  upvotes   ImprovementUpvote[]

  @@map("improvement_requests")
}

model ImprovementUpvote {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  improvementId String   @db.ObjectId
  phone         String
  createdAt     DateTime @default(now())

  improvement ImprovementRequest @relation(fields: [improvementId], references: [id], onDelete: Cascade)

  @@map("improvement_upvotes")
}

model ServiceMonitor {
  id                   String        @id @default(auto()) @map("_id") @db.ObjectId
  name                 String
  productId            String?       @db.ObjectId
  url                  String
  method               String        @default("GET")
  expectedStatusCode   Int           @default(200)
  checkIntervalSeconds Int           @default(300)
  currentStatus        ServiceStatus @default(UNKNOWN)
  responseTimeMs       Int?
  isActive             Boolean       @default(true)
  lastCheckedAt        DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  product   Product?     @relation(fields: [productId], references: [id])
  logs      MonitorLog[]
  incidents Incident[]

  @@map("service_monitors")
}

model MonitorLog {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  serviceMonitorId String       @db.ObjectId
  status          ServiceStatus
  responseTimeMs  Int?
  statusCode      Int?
  checkedAt       DateTime      @default(now())
  errorMessage    String?

  serviceMonitor ServiceMonitor @relation(fields: [serviceMonitorId], references: [id], onDelete: Cascade)

  @@map("monitor_logs")
}

model Incident {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  serviceMonitorId  String?          @db.ObjectId
  title             String
  description       String?
  severity          IncidentSeverity @default(HIGH)
  status            IncidentStatus   @default(OPEN)
  startedAt         DateTime         @default(now())
  resolvedAt        DateTime?
  durationMinutes   Int?
  rootCause         String?
  responsibleUserId String?          @db.ObjectId
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  serviceMonitor  ServiceMonitor? @relation(fields: [serviceMonitorId], references: [id])
  responsibleUser User?           @relation(fields: [responsibleUserId], references: [id])

  @@map("incidents")
}

model KnowledgeArticle {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  productId   String?         @db.ObjectId
  category    ArticleCategory @default(COMMON_QUESTIONS)
  content     String
  status      ArticleStatus   @default(DRAFT)
  createdById String          @db.ObjectId
  updatedById String?         @db.ObjectId
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  product   Product? @relation(fields: [productId], references: [id])
  createdBy User     @relation("ArticleCreatedBy", fields: [createdById], references: [id])
  updatedBy User?    @relation("ArticleUpdatedBy", fields: [updatedById], references: [id])

  @@map("knowledge_articles")
}

model TelegramSetting {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  botToken  String   @default("")
  phones    String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("telegram_settings")
}

model Client {
  id                 String             @id @default(auto()) @map("_id") @db.ObjectId
  fullName           String
  phone              String
  direction          String?
  position           String?
  location           String?
  branchCount        Int                @default(1)
  employeeCount      Int                @default(0)
  referredFrom       String?
  note               String?
  isActive           Boolean            @default(true)
  createdById        String?            @db.ObjectId
  productId          String?            @db.ObjectId
  installationStatus InstallationStatus @default(NEW)
  bitrixStatus       BitrixStatus       @default(NOT_ADDED)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  createdBy   User?    @relation("ClientCreatedBy", fields: [createdById], references: [id])
  product     Product? @relation(fields: [productId], references: [id])
  comments    ClientComment[]

  @@map("clients")
}

model ClientComment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  clientId    String   @db.ObjectId
  text        String
  createdById String   @db.ObjectId
  createdAt   DateTime @default(now())

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@map("client_comments")
}

model Difficulty {
  id               String           @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  productId        String?          @db.ObjectId
  clientPhone      String?
  description      String
  status           DifficultyStatus @default(NEW)
  reportedByCount  Int              @default(1)
  createdById      String           @db.ObjectId
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  product   Product? @relation(fields: [productId], references: [id])
  createdBy User     @relation("DifficultyCreatedBy", fields: [createdById], references: [id])
  upvotes   DifficultyUpvote[]

  @@map("difficulties")
}

model BugUpvote {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  bugId     String   @db.ObjectId
  phone     String
  createdAt DateTime @default(now())

  bug Bug @relation(fields: [bugId], references: [id], onDelete: Cascade)

  @@map("bug_upvotes")
}

model DifficultyUpvote {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  difficultyId String   @db.ObjectId
  phone        String
  createdAt    DateTime @default(now())

  difficulty Difficulty @relation(fields: [difficultyId], references: [id], onDelete: Cascade)

  @@map("difficulty_upvotes")
}
